APP_NAME=SiteBuddy
APP_ENV=local
APP_KEY=base64:$(openssl rand -base64 32)
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sitebuddy_db
DB_USERNAME=sitebuddy_user
DB_PASSWORD=sitebuddy_secure_password

FIREBASE_PROJECT_ID=sitebuddy-official
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json
